# Automatically loaded by both ai-monitor-server and ai-monitor-sync when this
# file lives in the current working directory.

# Server configuration
AI_MONITOR_DATABASE_PATH=ai_monitor.db
AI_MONITOR_CLIENT_IMAGE=ghcr.io/cytadela8-ai/ai-monitor-client:latest
AI_MONITOR_ADMIN_KEY=replace-me
AI_MONITOR_SESSION_SECRET=replace-me-too
AI_MONITOR_LOCAL_MACHINE_LABEL=main-server
AI_MONITOR_HOST=127.0.0.1
AI_MONITOR_PORT=8000

# Shared local provider paths
AI_MONITOR_CLAUDE_HISTORY_PATH=~/.claude/history.jsonl
AI_MONITOR_CODEX_HISTORY_PATH=~/.codex/history.jsonl
AI_MONITOR_CODEX_SESSIONS_ROOT=~/.codex/sessions

# Client-only configuration
AI_MONITOR_SERVER_URL=https://monitor.example.com
AI_MONITOR_API_KEY=replace-with-machine-key
